<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- === PALETA PRINCIPAL === -->
    <!-- Naranja cálido - color primario de la app -->
    <Color x:Key="ColorPrimario">#F97316</Color>
    <Color x:Key="ColorPrimarioClaro">#FDBA74</Color>
    <Color x:Key="ColorPrimarioOscuro">#EA580C</Color>

    <!-- Fondos cálidos -->
    <Color x:Key="ColorFondo">#FFF7ED</Color>
    <Color x:Key="ColorFondoTarjeta">#FFFFFF</Color>
    <Color x:Key="ColorFondoSecundario">#FEF3C7</Color>

    <!-- Verde salud -->
    <Color x:Key="ColorSalud">#0D9488</Color>
    <Color x:Key="ColorSaludClaro">#CCFBF1</Color>

    <!-- Rojo emergencia - NUNCA usar para otra cosa -->
    <Color x:Key="ColorEmergencia">#DC2626</Color>
    <Color x:Key="ColorEmergenciaOscuro">#B91C1C</Color>

    <!-- Violeta juegos -->
    <Color x:Key="ColorJuegos">#7C3AED</Color>

    <!-- Azul contactos -->
    <Color x:Key="ColorContactos">#1D4ED8</Color>

    <!-- Texto -->
    <Color x:Key="ColorTexto">#1C1917</Color>
    <Color x:Key="ColorTextoSecundario">#78716C</Color>
    <Color x:Key="ColorTextoInverso">#FFFFFF</Color>

    <!-- Separadores y bordes -->
    <Color x:Key="ColorBorde">#E7E5E4</Color>
    <Color x:Key="ColorSombra">#00000020</Color>

    <!-- Estado: completado -->
    <Color x:Key="ColorCompletado">#16A34A</Color>
    <Color x:Key="ColorCompletadoClaro">#DCFCE7</Color>

</ResourceDictionary>
